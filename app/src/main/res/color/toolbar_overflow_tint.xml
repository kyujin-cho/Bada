<?xml version="1.0" encoding="utf-8"?>
<!--
  Tint state list applied to MainActivity's overflow (kebab) icon
  via `ic_overflow_kebab.xml`'s `android:tint`. The pressed entry
  shifts the icon glyph from the default near-black tone to a
  mid-gray tone, so on touch-down the icon visibly "lights up" /
  fades brighter without ever painting a rectangular background
  press wash behind it. The non-pressed default mirrors the
  AppCompat overflow icon's standard ink colour so the resting
  state matches every other dark-glyph icon on the toolbar.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" android:color="#FF8E8E93" />
    <item android:color="#FF1A1A1A" />
</selector>
