<?xml version="1.0" encoding="utf-8"?>
<!--
  Tint state list applied to MainActivity's overflow (kebab) icon
  via `ic_overflow_kebab.xml`'s `android:tint`. The pressed entry
  shifts the icon glyph to a mid-gray secondary tone so on touch-
  down the icon visibly "lights up" / fades brighter without ever
  painting a rectangular background press wash behind it. The
  non-pressed default uses the platform's primary text color so
  the icon adapts automatically to day/night mode — near-black on
  light, near-white on dark. (The earlier hard-coded `#FF1A1A1A`
  was invisible against the dark page bg in night mode; routing
  through the theme attribute keeps that contrast healthy on
  whatever surface the toolbar paints in either mode.)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" android:color="?android:attr/textColorSecondary" />
    <item android:color="?android:attr/textColorPrimary" />
</selector>
