<?xml version="1.0" encoding="utf-8"?>
<!--
  Drag-handle pill rendered at the very top of the bottom sheets in
  the app (currently the "Can't find the device?" sheet). 4dp tall,
  fully-rounded. Uses `@color/bottom_sheet_drag_handle` (mid-black
  on the light sheet surface, mid-white on the dark sheet surface)
  so it reads as a subtle "drag me" affordance on either mode
  without competing with the headline below.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="2dp" />
    <solid android:color="@color/bottom_sheet_drag_handle" />
</shape>
