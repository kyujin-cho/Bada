<?xml version="1.0" encoding="utf-8"?>
<!--
  Global button background. Applied to every plain `<Button>` via
  `Theme.LibreDrop`'s `buttonStyle` override so the entire app moves
  off the dull AppCompat gray onto a soft "frosted glass" surface
  with rounded ends.

  Layers (top â†’ bottom in z-order; bottom listed first because that
  is how the platform composites a `<ripple>` drawable):

    * Default state â€” a faint cool-gray tint (`#1AF2F4F7`, ~10%
      alpha) inside a 1dp `#22000000` border at 24dp corner radius.
      Reads as a translucent "lifted glass" plate against any white
      / blurred-white surface in the app.
    * Disabled state â€” drops to a flat `#0A000000` (~4% black) with
      no border so the button visibly steps back without a heavy
      gray box.
    * Ripple on top â€” uses the brand blue at low alpha
      (`#1F0F62FE`, ~12%) so a tap glows softly inside the rounded
      shape. The `@android:id/mask` shape clips the ripple to the
      same 24dp corner radius â€” without it, the ripple would spill
      out of the rounded ends as a square.

  Borderless variants (`?android:attr/borderlessButtonStyle`, used
  for Skip / Reset) opt out of this drawable on a per-Button basis,
  keeping the lighter visual weight where we want a secondary
  action.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#1F0F62FE">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <solid android:color="#33000000" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
            <item>
                <!--
                  Default fill bumped from a near-invisible 10% cool
                  gray to a 60% translucent white so the button stands
                  out clearly on top of the success card's blurred
                  image backdrop. Stays translucent enough to read as
                  "frosted glass" rather than a solid plate, while the
                  subtle 13% black border keeps the edge defined
                  against any background tone.
                -->
                <shape android:shape="rectangle">
                    <solid android:color="#99FFFFFF" />
                    <stroke
                        android:width="1dp"
                        android:color="#22000000" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
        </selector>
    </item>

</ripple>
