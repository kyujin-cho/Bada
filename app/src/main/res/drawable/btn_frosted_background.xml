<?xml version="1.0" encoding="utf-8"?>
<!--
  Global button background. Applied to every plain `<Button>` via
  `Theme.Bada`'s `buttonStyle` override so the entire app moves
  off the dull AppCompat gray onto a soft "frosted glass" surface
  with rounded ends.

  Layers (top → bottom in z-order; bottom listed first because that
  is how the platform composites a `<ripple>` drawable):

    * Default state — `@color/frosted_button_fill` (translucent
      white in day, translucent white-on-dark in night) inside a
      1dp `@color/frosted_button_stroke` border at 24dp corner
      radius. Reads as a translucent "lifted glass" plate against
      any surface in the app, on either mode.
    * Disabled state — drops to `@color/frosted_button_disabled`
      (low-alpha black/white) with no border so the button visibly
      steps back without a heavy gray box.
    * Ripple — uses `@color/frosted_button_ripple` (brand blue in
      day, lighter brand tint in night) so a tap glows softly
      inside the rounded shape. The `@android:id/mask` shape clips
      the ripple to the same 24dp corner radius — without it, the
      ripple would spill out of the rounded ends as a square.

  Borderless variants (`?android:attr/borderlessButtonStyle`, used
  for Skip / Reset) opt out of this drawable on a per-Button basis,
  keeping the lighter visual weight where we want a secondary
  action.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/frosted_button_ripple">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <solid android:color="@color/frosted_button_disabled" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/frosted_button_fill" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/frosted_button_stroke" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
        </selector>
    </item>

</ripple>
