<?xml version="1.0" encoding="utf-8"?>
<!--
  Window background for the ConsentTrampolineActivity dialog theme.
  20dp corner radius surface so the activity reads as a card
  floating over whatever's underneath when Full-Screen-Intent raises
  it on top of another app or the lock screen.

  The fill is a very subtle vertical gradient via the
  `card_dialog_gradient_*` tokens — barely-tinted sky blue at top
  fading to neutral surface at bottom in day mode; barely-tinted
  navy at top fading to dark surface at bottom in night mode. The
  intent is "this surface is alive, not flat" without reading as a
  colored card; on most displays the tint is only perceptible in
  direct comparison to a solid surface. The corresponding gradient
  on the sender card lives in `dialog_gradient_background.xml`; the
  two drawables share the same tokens so the consent and send
  surfaces feel like the same family on either mode.

  Gradient `angle="270"` is "top → bottom" in Android's drawable
  convention (90° clockwise from "left → right"), which matches the
  "tinted top fading to neutral floor" motif.

  The platform draws its own dim layer behind the dialog window, so
  this drawable only paints the foreground card.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="20dp" />
    <gradient
        android:angle="270"
        android:endColor="@color/card_dialog_gradient_bottom"
        android:startColor="@color/card_dialog_gradient_top"
        android:type="linear" />
</shape>
