<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom toolbar overflow icon. Two hollow ring outlines stacked
  vertically, matching the vivo / OriginOS "more options" pattern
  (the stock Android material kebab is three filled dots; vivo uses
  two strokes-only rings).

  Each ring: outer radius 3.0dp, stroke width 2.0dp, no fill, in a
  24dp viewport centered at x=12. Centers at y=7 and y=17 so the
  pair fills more of the viewport (rings span y=4 to y=20 with a
  ~2dp gap between them) and reads as the bold visual weight the
  vivo / OriginOS native rings carry — pixel-comparable to the
  rings in the screenshot side-by-side.

  Stroke colour is wired to the `toolbar_overflow_tint` state list
  so the rings shift to a brighter mid-gray on `state_pressed` —
  that brightening IS the tap feedback. The toolbar's
  `actionBarItemBackground` is fully transparent for every state
  (see `toolbar_action_background.xml`), so no rectangular press
  wash or ripple ever paints behind the icon; the user perceives
  the tap as "the icon lit up" rather than "the button got
  highlighted".

  Note: `strokeColor` accepts ColorStateList resources directly on
  AnimatedVectorDrawable / VectorDrawable — the rings re-evaluate
  the state list when the parent ImageButton's state changes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:pathData="M12,7 m-3.0,0 a3.0,3.0 0 1,0 6.0,0 a3.0,3.0 0 1,0 -6.0,0 M12,17 m-3.0,0 a3.0,3.0 0 1,0 6.0,0 a3.0,3.0 0 1,0 -6.0,0"
        android:strokeColor="@color/toolbar_overflow_tint"
        android:strokeWidth="2.0" />
</vector>
