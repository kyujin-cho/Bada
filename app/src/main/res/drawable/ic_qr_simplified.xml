<?xml version="1.0" encoding="utf-8"?>
<!--
  Simplified QR-code glyph for the send card's top-right share
  button. Three solid corner finder squares (top-left / top-right /
  bottom-left) plus a scatter of small data dots in the
  bottom-right quadrant — enough visual signal to read as "QR" at
  a glance without the complexity of a real QR encoding.

  All paths fill in white so the icon stands out on the deep-blue
  gradient background defined by `qr_button_background`.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Three corner finder patterns -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M3,3 h6 v6 h-6 z M15,3 h6 v6 h-6 z M3,15 h6 v6 h-6 z" />

    <!-- Data dots in the remaining quadrants -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M11,11 h2 v2 h-2 z
                          M14,13 h2 v2 h-2 z
                          M11,15 h2 v2 h-2 z
                          M16,16 h2 v2 h-2 z
                          M19,11 h2 v2 h-2 z
                          M19,18 h2 v2 h-2 z
                          M14,19 h2 v2 h-2 z" />

</vector>
