<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-item background for the landscape floating nav. The selected
  (checked) tab gets the full-cell capsule highlight; every other tab is
  transparent. Set as `app:itemBackground` so it covers the whole item
  (icon + label), not just the icon.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/nav_item_active_pill"
        android:state_checked="true" />
    <item android:drawable="@android:color/transparent" />
</selector>
