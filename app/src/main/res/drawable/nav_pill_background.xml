<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill background for the bottom navigation in landscape. The bar is
  pulled out of the vertical stack and floated in the bottom-left corner
  as a rounded capsule, so it needs its own surface + hairline edge
  (portrait draws the bar transparent against the activity surface). The
  32dp corner radius is half the 64dp bar height, giving fully round
  ends; the soft elevation set on the view itself lifts it off the
  content behind it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/nav_surface" />
    <corners android:radius="32dp" />
    <stroke
        android:width="1dp"
        android:color="@color/surface_card_stroke" />
</shape>
