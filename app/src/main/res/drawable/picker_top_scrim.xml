<?xml version="1.0" encoding="utf-8"?>
<!--
  Top scrim for the send-screen peer list: a vertical gradient from the
  card's upper surface colour (opaque) at the top down to transparent.
  Drawn over the top of the scrolling list so rows pass UNDER it and fade
  into the card surface as they scroll up, instead of overflowing past the
  top of the gradient card. The opaque colour matches
  card_dialog_gradient_top (the card surface near its top) so there is no
  visible seam; pairs with picker_bottom_scrim.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:endColor="#00EFF5FC"
        android:startColor="#FFEFF5FC" />
</shape>
