<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft chip-style background for the URL row inside the QR sharing
  panel (see `send_qr_url`). 12dp rounded corners and a very light
  gray fill (`#F2F4F7`, ~5% black) read as a subtle "selectable
  field" container without adding visual weight that competes with
  the QR bitmap above. A 1dp hairline at `#1A000000` (~10% black)
  gives the chip a defined edge against the white card surface
  beneath it; without the stroke the chip nearly disappears on
  bright displays.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <solid android:color="#F2F4F7" />
    <stroke
        android:width="1dp"
        android:color="#1A000000" />
</shape>
