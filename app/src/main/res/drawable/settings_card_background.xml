<?xml version="1.0" encoding="utf-8"?>
<!--
  Section panel surface for the Settings tab. White fill, 16dp
  rounded corners, and a 1dp `#14000000` hairline (matching the
  ambient-shadow alpha used by SendActivity's MaterialCardView)
  give each setting group a soft "card" container without the
  full elevation/drop-shadow weight that the share-flow's floating
  card carries.

  Why a flat panel instead of MaterialCardView: the Settings tab
  scrolls a stack of four sections — adding a real elevated card
  to each would create competing shadows and read as visual noise.
  A flat-but-bordered panel groups each setting visually while
  staying calm; it also matches the layered "card-on-card" idiom
  used inside SendActivity (the floating card + chip-style URL
  field) without re-introducing a second floating layer.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <solid android:color="#FFFFFFFF" />
    <stroke
        android:width="1dp"
        android:color="#14000000" />
</shape>
