<?xml version="1.0" encoding="utf-8"?>
<!--
  Section panel surface for the Settings tab. White card in day mode
  / dark surface in night mode via `@color/surface_card`; matching
  hairline edge via `@color/surface_card_stroke` (alpha-black in
  day, alpha-white in night) so the panel reads as a card against
  either page bg.

  Why a flat panel instead of MaterialCardView: the Settings tab
  scrolls a stack of four sections — adding a real elevated card
  to each would create competing shadows and read as visual noise.
  A flat-but-bordered panel groups each setting visually while
  staying calm; it also matches the layered "card-on-card" idiom
  used inside SendActivity (the floating card + chip-style URL
  field) without re-introducing a second floating layer.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <solid android:color="@color/surface_card" />
    <stroke
        android:width="1dp"
        android:color="@color/surface_card_stroke" />
</shape>
