<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape variant of SendActivity (#24). Portrait stacks everything
  inside a fixed 480dp centered card (see res/layout/activity_send.xml);
  in landscape the short viewport would push the peer list and the
  Cancel button below the fold. Landscape instead drops the card and
  splits the content area left/right so the picker fits without
  scrolling the whole screen:

    * LEFT half  — the "title" block (payload summary + size + subtitle),
      with the rejection banner and the "Can't find the device?" help
      link aligned at the bottom of the column.
    * RIGHT half — the peer list (send_peer_scroll), which scrolls; the
      Cancel / Done buttons are pinned to the bottom-right (half width)
      and stay visible without scrolling, with the list scrolling behind
      them. The status panel (sending / PIN / terminal) center-aligns in
      this same right half.

  Every id SendActivity / SendPeerPickerController look up is present
  here (identical types where the code calls type-specific methods) so
  the same ViewBinding-driven code drives both orientations. The blur /
  gradient / PIN backgrounds, the QR panel and the floating Show-QR icon
  stay as full-content overlays exactly as in portrait.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Compact send toolbar with the centered device-name pill (see
         portrait layout for the inset/centering rationale; the height /
         padding come from values-land/dimens.xml). -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/send_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_toolbar_height"
        android:background="?android:attr/colorBackground"
        android:paddingTop="@dimen/app_toolbar_padding_top"
        app:contentInsetEnd="0dp"
        app:contentInsetLeft="0dp"
        app:contentInsetRight="0dp"
        app:contentInsetStart="0dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/send_device_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/send_device_pill_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="Pixel 8" />

        </com.google.android.material.card.MaterialCardView>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Full-bleed content area. Holds the same layered children as the
         portrait card interior (backgrounds → picker → QR → Show-QR),
         but laid out across the whole landscape viewport. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="32dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/dialog_gradient_background" />

        <View
            android:id="@+id/send_pin_state_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/pin_state_background"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/send_card_blur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <View
            android:id="@+id/send_card_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/card_blur_overlay"
            android:visibility="gone" />

        <!--
          Picker content. FrameLayout (not the portrait LinearLayout) so
          the left/right split, the centered status panel and the
          bottom-right button bar can layer cleanly. SendActivity only
          ever calls View-level methods on send_picker_content
          (alpha / visibility / animate), so the ViewBinding type
          difference is harmless.
        -->
        <FrameLayout
            android:id="@+id/send_picker_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Left/right split. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">

                <!-- LEFT: title block + help link pinned to the bottom. -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="24dp">

                    <!-- Title row: payload summary / size / subtitle on the
                         left; the Show-QR button pinned to the RIGHT edge
                         of the left half (next to the column divider) so it
                         never overlaps the peer list in the right half. -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/send_payload_summary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                                android:textStyle="bold"
                                tools:text="1 file" />

                            <TextView
                                android:id="@+id/send_payload_size"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                                android:textColor="?android:attr/textColorSecondary"
                                android:visibility="gone"
                                tools:text="4.2 MB"
                                tools:visibility="visible" />

                            <TextView
                                android:id="@+id/send_subtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/send_subtitle_discovering"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/send_show_qr_button"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="top"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/qr_button_subtle_background"
                            android:contentDescription="@string/send_show_qr"
                            android:padding="10dp"
                            android:src="@drawable/ic_qr_code"
                            android:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <!-- Pushes the rejection banner + help link to the
                         bottom of the left column. -->
                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/send_rejection_banner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/rejection_banner_background"
                        android:elevation="2dp"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="V2547A 님이 파일 전송을 거절했습니다." />

                    <TextView
                        android:id="@+id/send_help_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="@string/send_help_link"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>

                <!-- RIGHT: peer list (scrolls) + pinned Cancel/Done +
                     centered status panel. -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- The list. clipToPadding=false + a bottom padding
                         the height of the button row lets the last peer
                         scroll up clear of the floating Cancel button
                         rather than sitting permanently behind it. -->
                    <ScrollView
                        android:id="@+id/send_peer_scroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:fillViewport="true"
                        android:paddingBottom="72dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:id="@+id/send_peer_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <TextView
                                android:id="@+id/send_empty_state"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="24dp"
                                android:text="@string/send_empty_state"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/send_network_hint"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:background="?android:attr/colorBackgroundFloating"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/send_network_hint_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/send_network_hint_title"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/send_network_hint_body"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/send_network_hint_body"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                                <Button
                                    android:id="@+id/send_network_hint_dismiss"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="end"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/send_network_hint_dismiss" />

                            </LinearLayout>

                        </LinearLayout>

                    </ScrollView>

                    <!-- Status panel (sending / awaiting PIN / terminal),
                         centered in the right half. Hidden during picking. -->
                    <LinearLayout
                        android:id="@+id/send_status_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/send_status_phase"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Title"
                            tools:text="Awaiting acceptance" />

                        <TextView
                            android:id="@+id/send_status_target"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            tools:text="Sending to Pixel 8" />

                        <FrameLayout
                            android:id="@+id/send_status_circle_wrapper"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:visibility="gone">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/send_status_circle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:indeterminate="false"
                                app:indicatorSize="72dp"
                                app:trackThickness="6dp" />

                            <TextView
                                android:id="@+id/send_status_circle_pct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textStyle="bold"
                                tools:text="42%" />

                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/send_terminal_preview_card"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/photo_card_background"
                            android:elevation="4dp"
                            android:padding="6dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/send_terminal_preview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/main_send_preview_photo_description"
                                android:scaleType="centerCrop" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/send_pin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:letterSpacing="0.4"
                            android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="1234" />

                        <TextView
                            android:id="@+id/send_status_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            tools:text="Confirm this code matches the receiver's screen." />

                    </LinearLayout>

                    <!-- Bottom-right action buttons, pinned and drawn on
                         top of the scrolling list. Cancel and Done are
                         mutually exclusive across states. -->
                    <Button
                        android:id="@+id/send_cancel_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:text="@string/send_cancel" />

                    <Button
                        android:id="@+id/send_done_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:text="@string/send_done"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- In-card QR panel, full-content overlay (unchanged from
             portrait). -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/send_qr_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/send_qr_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_qr_title"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/show_qr_intro"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                <ImageView
                    android:id="@+id/send_qr_bitmap"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/white"
                    android:contentDescription="@string/show_qr_image_description" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/qr_url_background"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <TextView
                        android:id="@+id/send_qr_url"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:singleLine="true"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                        android:textIsSelectable="true" />

                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/send_qr_close"
                        style="@style/Widget.Bada.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minWidth="140dp"
                        android:text="@string/show_qr_close"
                        android:textAlignment="center" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="wrap_content" />

                    <Button
                        android:id="@+id/send_qr_copy_link"
                        style="@style/Widget.Bada.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minWidth="140dp"
                        android:text="@string/show_qr_copy_link"
                        android:textAlignment="center" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
