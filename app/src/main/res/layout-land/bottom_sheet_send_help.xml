<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape variant of the "Can't find the device?" help bottom sheet.
  Portrait closes via a full-width button pinned at the bottom of the
  content (res/layout/bottom_sheet_send_help.xml); on the short landscape
  viewport that button would sit below the fold, so landscape instead
  replaces it with a compact "X" dismiss button pinned at the top-right
  corner, floating over the scrolling content. The dismiss view keeps the
  id @id/send_help_sheet_close so SendActivity wires the same listener in
  both orientations.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <!-- Drag-handle affordance. Decorative; the parent
                 BottomSheetDialog handles the actual swipe gesture. -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bottom_sheet_drag_handle" />

            <!-- Title reserves a right strip so the long title never runs
                 under the floating X button. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="44dp"
                android:text="@string/send_help_sheet_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                android:textStyle="bold" />

            <!-- Section 1: receiver visibility check. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/send_help_sheet_visibility_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/send_help_sheet_visibility_body"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

            <!-- Section 2: QR / link fallback. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/send_help_sheet_qr_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/send_help_sheet_qr_body"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

            <!-- Section 3: experimental-compatibility note. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/send_help_sheet_compat_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/send_help_sheet_compat_body"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Top-right X dismiss. Same id as the portrait close button so the
         existing SendActivity click wiring works unchanged. -->
    <ImageButton
        android:id="@+id/send_help_sheet_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/send_help_sheet_close"
        android:padding="8dp"
        android:src="@drawable/ic_close_24"
        android:tint="?android:attr/textColorSecondary" />

</FrameLayout>
