<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for ConsentTrampolineActivity (#22).

  This is the screen-on, lock-screen-bypassing dialog that opens when
  the user taps the consent notification body. The activity now hosts
  four sequential states inside a single dialog-themed window:

    1. consent_panel — Accept / Reject prompt with sender name, file
       summary, and the 4-digit PIN. Default visible state on entry.
    2. receiving_panel — circular CircularProgressIndicator + the
       running "12 MB / 100 MB" byte counter. Switched in once the
       user taps Accept; the activity then observes the in-flight
       InboundConnection's StateFlow to drive the progress bar.
    3. completed_panel — "Transfer complete" headline + an optional
       image preview (looked up via MediaStore for the most recent
       received file with an image MIME) + "View image" / "Close"
       buttons. Switched in on InboundConnectionState.Completed.
    4. failed_panel — "Transfer failed" / "Transfer cancelled"
       headline + a `Close` action. Switched in on
       InboundConnectionState.Cancelled / Failed / Rejected.

  All four panels share the same FrameLayout slot inside the
  ScrollView so the dialog window resizes to fit whichever panel is
  currently visible. Only one panel is visible at any time;
  ConsentTrampolineActivity flips visibility via
  TransitionManager.beginDelayedTransition with a ChangeBounds
  transition so the dialog smoothly resizes between states.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/consent_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <!--
      Inner content has a FIXED height of 480dp so the dialog never
      changes size between consent / receiving / completed / failed
      panels. Each panel inside is `match_parent` + `gravity="center"`
      so empty space lands symmetrically above and below regardless
      of which state is active. Mirrors the sender-card geometry so
      both completion surfaces share the same footprint.
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="480dp">

        <!--
          Blurred backdrop for the completed state. Mirrors the
          sender's `send_card_blur` + `send_card_overlay` pair: the
          ImageView sits at the back filling the FrameLayout via
          `centerCrop`, and the white sheet on top dampens the blur
          so the foreground panel content (title, preview, buttons)
          stays readable. Both default `gone`; ConsentTrampolineActivity
          flips them on once the receive completes and a representative
          bitmap is sampled out of MediaStore.
        -->
        <ImageView
            android:id="@+id/consent_card_blur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <View
            android:id="@+id/consent_card_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/card_blur_overlay"
            android:visibility="gone" />

        <!-- Consent state — initial. -->
        <LinearLayout
            android:id="@+id/consent_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title is centre-aligned and uses a type-specific
                 template ("…wants to share images / videos / files")
                 picked by ConsentTrampolineActivity from the
                 announced payload mime types. The earlier
                 left-aligned subtitle ("N items (size)") is gone —
                 the type-specific title carries that information now,
                 so the redundant count line was dropped. -->
            <TextView
                android:id="@+id/consent_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textStyle="bold"
                tools:text="Pixel 8 wants to share images" />

            <!-- `consent_subtitle` is intentionally `gone` in this
                 layout. The activity still has the view ID so legacy
                 code paths that look it up do not crash; nothing else
                 ever flips it back to VISIBLE. Keep the ID stable so
                 a future reinstatement does not require touching
                 every existing reference. -->
            <TextView
                android:id="@+id/consent_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:visibility="gone"
                tools:text="3 files (12.4 MB)" />

            <!-- "PIN" label centred above the 4-digit confirmation
                 code so the label and the code share a vertical
                 axis. The verbose "Confirm this 4-digit code matches
                 the sender's screen" line is replaced by the short
                 "PIN" header per design simplification. -->
            <TextView
                android:id="@+id/consent_pin_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/consent_pin_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

            <TextView
                android:id="@+id/consent_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:letterSpacing="0.4"
                android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                android:textStyle="bold"
                tools:text="1234" />

            <!-- Files heading is centre-aligned to match the title /
                 PIN label, giving the panel a single shared centre
                 axis. Individual file rows below stay left-aligned
                 because file names are read left-to-right. -->
            <TextView
                android:id="@+id/consent_files_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/consent_files_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

            <LinearLayout
                android:id="@+id/consent_files_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical" />

            <!--
              Accept / Reject in a horizontal 2-column row. Each
              button uses `layout_weight=1` so they share the panel
              width equally; the 12dp Space between provides a
              consistent gap matching the rest of the app's button
              rows. Reject is the leading (left) button so the
              primary destructive choice is reachable with the same
              thumb that just decided whether to accept.
            -->
            <!--
              Reject / Accept row centered as a group. See the
              completed-state row's comment for why we size each
              button to wrap_content + center the parent rather
              than splitting the row 50/50 with `weight=1`.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/consent_reject_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minWidth="140dp"
                    android:text="@string/consent_button_reject"
                    android:textAlignment="center" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/consent_accept_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minWidth="140dp"
                    android:text="@string/consent_button_accept"
                    android:textAlignment="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Receiving state. -->
        <LinearLayout
            android:id="@+id/consent_receiving_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/consent_receiving_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_state_receiving"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/consent_receiving_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorSize="72dp"
                    app:trackThickness="6dp" />

                <TextView
                    android:id="@+id/consent_receiving_progress_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textStyle="bold"
                    tools:text="42%" />

            </FrameLayout>

            <TextView
                android:id="@+id/consent_receiving_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                tools:text="12 MB / 100 MB" />

            <TextView
                android:id="@+id/consent_expert_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                android:textColor="?android:attr/textColorSecondary"
                android:visibility="gone"
                tools:text="Speed: 12.4 MB/s&#10;ETA: 30 seconds&#10;Medium: Wi-Fi LAN" />

        </LinearLayout>

        <!-- Completed state. -->
        <LinearLayout
            android:id="@+id/consent_completed_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/consent_completed_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_state_completed"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textStyle="bold" />

            <!--
              Polaroid wrapper around the completed-state preview —
              same `photo_card_background` + 6dp padding + 4dp
              elevation as the sender's success card so the two
              completion surfaces read as the same family.
              ConsentTrampolineActivity toggles the WRAPPER's visibility
              once the MediaStore preview lookup resolves; the inner
              ImageView only ever holds the bitmap.
            -->
            <FrameLayout
                android:id="@+id/consent_completed_preview_card"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/photo_card_background"
                android:elevation="4dp"
                android:padding="6dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/consent_completed_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/main_send_preview_photo_description"
                    android:scaleType="centerCrop" />

            </FrameLayout>

            <TextView
                android:id="@+id/consent_completed_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                tools:text="1 file received" />

            <!--
              Close / View image as a horizontal row centered as a
              group. Both buttons size to `wrap_content` so a longer
              label ("View received image") doesn't reserve the same
              50% slot a shorter label ("닫기") would — keeping equal
              weight made the row read as off-center because the
              empty padding around "닫기" was visibly larger than the
              empty padding around "이미지 보기". With wrap_content +
              parent `gravity=center`, the button group recenters as
              labels grow / shrink with locale, and `minWidth` keeps
              even single-character labels from collapsing to a
              cramped pill.

              `consent_completed_view_button` starts hidden and
              ConsentTrampolineActivity reveals it only after the
              MediaStore lookup resolves to an image Uri. When the
              View button is hidden, Close stands alone, still
              centered horizontally by the parent's gravity.
            -->
            <!--
              Button row implemented as FrameLayout-wrapped
              TextView pairs instead of plain `<Button>`. Multiple
              attempts at centering Button text via the
              `Widget.Bada.Button` style (gravity=center,
              textAlignment=center, paddingStart/End reset,
              drawablePadding=0dp, iconGravity=textTop, etc.) all
              left Korean labels visibly LEFT of the button
              centerline on this Bridge-theme AppCompatButton
              build — root cause never isolated.

              The wrapper pattern sidesteps the issue entirely: the
              FrameLayout carries the frosted background + click
              behavior, while the inner wrap_content TextView is
              positioned via `android:layout_gravity="center"`,
              which is FrameLayout's own centering logic — that
              path always produces a true geometric center
              regardless of text content, locale, or font metrics.
              The TextView's intrinsic width matches its glyph
              run, so visual center == geometric center == layout
              center.

              `consent_completed_view_button` (the FrameLayout id)
              starts hidden; ConsentTrampolineActivity reveals it
              only after the MediaStore lookup resolves to an
              image Uri. When the View button is hidden the spacer
              hides too and Close fills the row alone via the
              shared `weight=1`.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/consent_completed_close_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/btn_frosted_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="48dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="12dp"
                        android:text="@string/consent_state_close"
                        android:textAppearance="@style/TextAppearance.Bada.Button"
                        android:textColor="?android:attr/textColorPrimary" />

                </FrameLayout>

                <Space
                    android:id="@+id/consent_completed_button_gap"
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/consent_completed_view_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/btn_frosted_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="48dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="12dp"
                        android:text="@string/consent_state_view_image"
                        android:textAppearance="@style/TextAppearance.Bada.Button"
                        android:textColor="?android:attr/textColorPrimary" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Failed / cancelled / rejected state. -->
        <LinearLayout
            android:id="@+id/consent_failed_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/consent_failed_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_state_failed"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/consent_failed_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:visibility="gone"
                tools:text="UKEY2 BAD_VERSION" />

            <Button
                android:id="@+id/consent_failed_close_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/consent_state_close" />

        </LinearLayout>

    </FrameLayout>

</ScrollView>
