<?xml version="1.0" encoding="utf-8"?>
<!--
  Credit screen. Three primary categories (Developer, Polisher, QA)
  plus a "Special Thanks to" footer rendered in a different style
  (no avatar, single-line caption centered at the bottom).

  Each main-category row pairs a 64dp square placeholder image
  (left) with a nickname + one-line description stack (right). The
  outer horizontal LinearLayout uses `gravity="center_vertical"` so
  the avatar and text stack share a vertical center line — without
  this the LinearLayout would top-align both children and the avatar
  square would jut up past a single-line text stack.

  The nickname TextView IDs are exposed individually so
  CreditActivity can install the diagonal blue-gradient sweep
  animation per name on a 500ms staggered schedule.

  Toolbar geometry matches the rest of the app's vivo-style header
  (88dp tall + 32dp top padding + 32sp bold title) so the screen
  feels like part of the main app shell when the user lands here
  from MainActivity's overflow menu.
-->
<!--
  Outer container background is the same `colorBackground` (~#fafafa)
  the toolbar uses, NOT pure white. Combined with `fitsSystemWindows`
  this lets the LinearLayout absorb the status bar inset as TOP
  PADDING and paint the same gray strip the toolbar paints, so the
  system status bar reads as one continuous surface with the
  toolbar instead of a stark white band sitting above a gray bar.

  The page body (the ScrollView below) has its own white surface
  layered on top, so the status-bar gray ends precisely where the
  toolbar ends and the contributor list still reads on a clean
  white sheet.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/credit_toolbar"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="?android:attr/colorBackground"
        android:paddingEnd="12dp"
        android:paddingTop="32dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/credit_activity_label"
        app:titleCentered="false"
        app:titleTextAppearance="@style/TextAppearance.LibreDrop.ToolbarTitle"
        app:titleTextColor="?android:attr/textColorPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ============================================ -->
            <!-- Developer                                    -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/credit_section_developer"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/credit_kevin_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/credit_avatar_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/credit_kevin_avatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.LibreDrop.CreditAvatar"
                    app:strokeColor="@color/credit_avatar_stroke"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/credit_kevin_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/credit_kevin_name"
                        android:textAppearance="@style/TextAppearance.AppCompat.Title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/credit_kevin_desc"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                </LinearLayout>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- Polisher                                     -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/credit_section_polisher"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/credit_yeonfeel_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/credit_avatar_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/credit_yeonfeel_avatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.LibreDrop.CreditAvatar"
                    app:strokeColor="@color/credit_avatar_stroke"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/credit_yeonfeel_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/credit_yeonfeel_name"
                        android:textAppearance="@style/TextAppearance.AppCompat.Title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/credit_yeonfeel_desc"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                </LinearLayout>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- QA                                           -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/credit_section_qa"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/credit_chiyak_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/credit_avatar_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/credit_chiyak_avatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.LibreDrop.CreditAvatar"
                    app:strokeColor="@color/credit_avatar_stroke"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/credit_chiyak_qa_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/credit_chiyak_name"
                        android:textAppearance="@style/TextAppearance.AppCompat.Title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/credit_chiyak_qa_desc"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/credit_teqhnikacross_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/credit_avatar_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/credit_teqhnikacross_avatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.LibreDrop.CreditAvatar"
                    app:strokeColor="@color/credit_avatar_stroke"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/credit_teqhnikacross_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/credit_teqhnikacross_name"
                        android:textAppearance="@style/TextAppearance.AppCompat.Title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/credit_teqhnikacross_desc"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                </LinearLayout>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- Special Thanks to (compact footer)           -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="@string/credit_section_thanks"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="@string/credit_thanks_compact"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
