<?xml version="1.0" encoding="utf-8"?>
<!--
  MainActivity layout. Three-row vertical stack:

    1. @id/main_toolbar — MaterialToolbar at the top. Hosts the app
       title and the kebab overflow menu (defined in
       res/menu/main_overflow_menu.xml). Wired via
       `setSupportActionBar` in MainActivity.onCreate.
    2. @id/main_fragment_container — hosts SendReceiveFragment
       (default) or SettingsFragment.
    3. @id/main_bottom_nav — the persistent tab bar; menu definition
       in res/menu/bottom_nav_menu.xml.

  All of the per-tab UI lives inside the two fragments. MainActivity
  itself is a thin shell: it handles the onboarding gate, the
  receiver-foreground-service kick, and the tab/overflow wiring.

  System-bar inset handling:
    * `fitsSystemWindows="true"` on the root LinearLayout makes the
      view absorb the status-bar inset on top and the navigation-bar
      inset on bottom as `padding`. Without this the activity draws
      under the system bars on Android 15+ (compileSdk 36 enforces
      edge-to-edge).
    * The bottom inset lands on the BottomNavigationView via the
      LinearLayout's bottom padding so the tab bar does not collide
      with the gesture handle.

  Visual styling:
    * The toolbar uses the same light surface as the rest of the
      activity (`?attr/colorBackground`) so it blends with the
      content area; the kebab overflow icon picks up
      `?attr/colorControlNormal` automatically and reads as a dark
      glyph against the light bar.
    * The bottom bar uses `nav_surface` with `bottom_nav_item_color`
      tinting so active + inactive tabs both stay visible against a
      clean light surface, matching the vivo / OriginOS system theme.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!--
      Toolbar geometry follows the vivo / OriginOS native pattern:
        * `layout_height="88dp"` — taller than the AOSP default 56dp.
        * `paddingTop="32dp"` — pushes the title + action row to the
          bottom 56dp of the toolbar so the title sits near the
          content below it, not floating in the center.
        * `paddingEnd="12dp"` — moves the kebab icon further inward
          from the right edge so it does not hug the screen border;
          matches vivo's native action-icon offset.
        * `app:titleTextAppearance` — 26sp bold title, matching the
          weighty header text on a vivo native screen. The title
          color is wired to `?android:attr/textColorPrimary` so it
          stays legible across DayNight switches.
    -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="?android:attr/colorBackground"
        android:paddingEnd="12dp"
        android:paddingTop="32dp"
        app:popupTheme="@style/ThemeOverlay.LibreDrop.PopupMenu"
        app:title="@string/app_name"
        app:titleCentered="false"
        app:titleTextAppearance="@style/TextAppearance.LibreDrop.ToolbarTitle"
        app:titleTextColor="?android:attr/textColorPrimary" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/main_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!--
      Bottom-bar geometry follows the vivo / OriginOS native pattern:
        * `layout_height="64dp"` — taller than the AOSP 56dp default
          to match the vivo native bar; the system bottom inset
          (gesture-handle area) is added on top of this via the
          parent LinearLayout's `fitsSystemWindows`, so the visual
          footprint comes out at ~88dp.
        * `app:elevation="0dp"` — kills the bar's top-edge drop
          shadow. vivo's native bar sits flush with the content
          above it; the shadow on the previous build came from the
          default 8dp elevation.
        * `app:itemBackground` and `app:itemRippleColor` both
          transparent — kills both the press ripple AND the active
          item background highlight, so tabs change only their
          icon / label color between states (no surface flash, no
          rounded backdrop).
        * `app:itemTextAppearance{Active,Inactive}` both pointing at
          the same 12sp style — locks the label size so it does not
          grow when a tab is selected (Material's default "shifting"
          behavior).
        * The press-time icon scale animation is wired up
          programmatically in MainActivity.installItemPressAnimations.
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/main_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/nav_surface"
        app:elevation="0dp"
        app:itemBackground="@android:color/transparent"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.LibreDrop.BottomNavLabel"
        app:itemTextAppearanceInactive="@style/TextAppearance.LibreDrop.BottomNavLabel"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
