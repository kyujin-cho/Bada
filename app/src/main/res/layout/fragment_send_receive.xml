<?xml version="1.0" encoding="utf-8"?>
<!--
  Send/Receive tab. Hosted by SendReceiveFragment inside MainActivity's
  bottom-navigation shell.

  Vertical stack inside a ScrollView so the layout still works on
  short screens once the conditional WVMG banner is visible.

  Layout order (top to bottom):
    1. Legacy WhenVivoMeetsGoogle migration banner (#145, conditional;
       non-dismissible — surfaced when a coresident pre-rename install
       is detected).
    2. Always-visible pill (#34, receiver visibility on/off). Sits
       directly under the toolbar so the on/off state is the first
       thing the user reads when entering the tab. The button uses
       the same 24dp pill silhouette as the rest of the app's
       primary buttons; ON is a blue gradient with a "Always visible"
       label, OFF is the frosted background with "Visible on scan".
    3. Photo preview area: a small "Waiting for files…" caption
       centered above two polaroid-style photo cards. The cards are
       lightly rotated and slightly offset on the X axis so they sit
       at irregular angles, a soft vivo-style decorative cue that
       this device is ready to receive.
    4. Send Files / Send Folder buttons in a horizontal 2-column
       row, each with `layout_weight=1`.

  All subtitle / description TextViews from the previous build have
  been removed per the spec — the buttons and the toggle's own label
  carry every label needed.

  The battery-optimization (#47) prompt is no longer surfaced as a
  banner here; it lives as a one-shot AlertDialog raised by
  MainActivity on first launch + a re-triggerable row on the Settings
  tab.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fillViewport="true">

    <!--
      `match_parent` height paired with the ScrollView's `fillViewport`
      lets the LinearLayout grow to fill the visible area when content
      is shorter than the viewport, so a `weight=1` Space below the
      photo previews can push the Send Files / Send Folder row down
      to the bottom of the screen rather than letting it float in the
      middle. When content is taller (e.g. with the legacy WVMG
      banner visible) the spacer collapses to 0 and the ScrollView
      handles the overflow as before.

      The always-visible ambient pulse layer that paints behind the
      whole screen (including the toolbar) lives at the activity
      level — see `activity_main.xml`'s root FrameLayout. The
      fragment itself has no opaque background so the activity
      backdrop bleeds through naturally.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:padding="24dp">

        <!--
          Legacy-WhenVivoMeetsGoogle banner (#145). Hidden by default;
          SendReceiveFragment reveals it only when the migration
          detector finds a coresident pre-rename install still on the
          device. The banner is non-dismissible — the legacy install
          registers a duplicate 0xFEF3 GATT service that defeats the
          Quick Share slot-redirect, so the user must actually
          uninstall the old package for off-LAN BLE bootstrap to work.
          The banner disappears automatically the next time onStart
          fires after the uninstall completes.
        -->
        <LinearLayout
            android:id="@+id/main_legacy_wvmg_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="?android:attr/colorBackgroundFloating"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/main_legacy_wvmg_banner_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_legacy_wvmg_banner_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/main_legacy_wvmg_banner_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/main_legacy_wvmg_banner_body"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/main_legacy_wvmg_banner_uninstall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_legacy_wvmg_banner_uninstall" />

            </LinearLayout>

        </LinearLayout>

        <!--
          Always-visible toggle (#34) rendered as an on/off pill button
          rather than a SwitchCompat row. Pinned to the very top of the
          fragment (just under the activity toolbar) so the discoverable-
          ness of this device is the first piece of state the user sees.
          Wiring lives in SendReceiveFragment.refreshVisibilityButton
          which swaps the background drawable + label between the ON
          (blue gradient + white text + "Always visible") and OFF
          (frosted + dark text + "Visible on scan") states.

          The pulse animation that emanates from this button's centre
          when the ON state is active is rendered by a sibling
          VisibilityPulseView at the fragment-level FrameLayout root —
          it sits behind every other child on the z-axis so the
          polaroid cards and "Waiting for files…" caption paint on
          top of the pulse without being displaced.
        -->
        <Button
            android:id="@+id/main_always_visible_button"
            style="@style/Widget.Bada.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_always_visible_off_title" />

        <!--
          Caption below the always-visible pill, OUTSIDE the button
          silhouette. Plain-language summary of what the current
          pill state actually does for the user; swapped in lockstep
          with the pill's label by `SendReceiveFragment.
          refreshVisibilityButton` (ON → caption_on; OFF → caption_off).
          The XML default mirrors the OFF state since that is the
          fragment's initial state on cold start.
        -->
        <TextView
            android:id="@+id/main_always_visible_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/main_always_visible_caption_off"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary" />

        <!--
          Top flex spacer paired with the matching one below the photo
          previews. Together they bracket the "Waiting for files…" +
          polaroid pair into the vertical center of the viewport while
          leaving the always-visible pill anchored to the top and the
          Send Files / Send Folder row anchored to the bottom. Both
          spacers carry the same `weight=1` so leftover height is
          split evenly above and below the centerpiece.
        -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--
          Photo preview area. The "Waiting for files…" caption sits
          above two polaroid-style photo cards. Each card is a
          FrameLayout with a white rounded background, a 6dp inner
          padding (which makes the white surface read as a thin
          border around the inner ImageView), and a small elevation
          for the drop shadow. Both cards are positioned `center` in
          the parent FrameLayout, then offset on the X axis and given
          a small rotation so they sit at irregular angles like
          tossed photos. SendReceiveFragment loads two random images
          from MediaStore into the inner ImageViews when
          READ_MEDIA_IMAGES is granted; without the permission the
          cards remain visible as decorative empty frames.
        -->
        <TextView
            android:id="@+id/main_send_waiting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/main_send_waiting"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!--
              Pre-rendered polaroid preview cards. The white frame,
              inner photo, drop shadow, AND the ±7° rotation are all
              baked into a single supersampled bitmap by
              `SendReceiveFragment.buildPolaroidBitmap` and shown in
              an axis-aligned ImageView — no view-level rotation, no
              software/hardware layer trickery. Doing the rotation in
              software at ~9× the display resolution and downsampling
              through the ImageView's bilinear+mipmap path produces
              clean diagonals at every transition (outer card edge,
              inner photo edge, and the photo content itself), where
              view-level rotation always left some stair-stepping at
              one boundary or another.

              The 160dp footprint is sized to fit a 120dp card after
              ±7° rotation (~134dp bounding) plus an ~8dp soft drop
              shadow margin. The bitmap is square, so a fitCenter
              ImageView preserves its aspect inside any density.
            -->
            <ImageView
                android:id="@+id/main_send_preview_photo_1"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:contentDescription="@string/main_send_preview_photo_description"
                android:scaleType="fitCenter"
                android:translationX="-32dp" />

            <ImageView
                android:id="@+id/main_send_preview_photo_2"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:contentDescription="@string/main_send_preview_photo_description"
                android:scaleType="fitCenter"
                android:translationX="32dp" />

        </FrameLayout>

        <!--
          Flex spacer between the photo previews and the Send action
          row. With the parent LinearLayout sized to `match_parent`
          (and the ScrollView's fillViewport), this Space soaks up
          all leftover vertical room and pushes the Send Files / Send
          Folder buttons down to the bottom of the visible area.
          Collapses to zero height when content overflows the
          viewport, so the buttons stay reachable via scroll on short
          screens or with the WVMG banner visible.
        -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--
          Send Files / Send Folder action row. Both buttons share the
          horizontal space equally via `layout_weight=1` so the pair
          edge-aligns with the always-visible pill above (which is
          `match_parent`): the file button's left edge sits flush
          with the pill's left edge, and the folder button's right
          edge sits flush with the pill's right edge. This is the
          home-tab-specific layout — the consent / QR / generic
          terminal-state rows use the wrap_content + center variant
          because they sit inside an open dialog area where label
          length asymmetry would read as an off-center group.
          Here the two pills are framed by the visibility pill above
          on the same column axis, so the visual cue is "rows aligned
          on a column" rather than "row centered in space".
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/main_send_files_button"
                style="@style/Widget.Bada.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/main_send_files_button" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/main_send_folder_button"
                style="@style/Widget.Bada.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/main_send_folder_button" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
