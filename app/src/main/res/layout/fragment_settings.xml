<?xml version="1.0" encoding="utf-8"?>
<!--
  Settings tab. Hosted by SettingsFragment inside MainActivity's
  bottom-navigation shell.

  Visual rhythm:
    Each setting group sits inside its own rounded white panel
    (`@drawable/settings_card_background`) with consistent inside
    padding, instead of sharing a single full-bleed LinearLayout.
    Pulls the page in line with the rest of the app, where the
    share flow uses a rounded MaterialCardView, the QR panel uses a
    chip-style URL field, and dialogs use rounded card surfaces —
    settings now reads as part of the same family rather than as a
    plain text page on white.

    Inside each panel:
      * Title (Subhead bold)
      * Subtitle (Small, secondary color)
      * Read-out chip — current persisted value rendered with the
        same `@drawable/qr_url_background` chip used by the QR panel
        so "current value" reads as a real field, not a footnote.
      * Action row — single full-width pill for one-button cards,
        or a two-equal-weight pill row mirroring the QR panel's
        Close + Copy link layout for cards with a primary +
        secondary action. The previous borderless secondary buttons
        were the only place in the app using that style; replacing
        them with a frosted pill keeps the button language uniform.

  Layout order (matches the previous fragment so user expectations
  about which control lives where are preserved):
    1. Save-location settings (#42).
    2. Advertised Quick Share name (#141).
    3. Background activity (#47 follow-up).
    4. Keep screen on during transfers (#219).
    5. Shake-to-report bug toggle (#166).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="@dimen/settings_content_bottom_padding">

        <!-- ============ Card 1: Save location ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/main_save_location_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_save_location_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/main_save_location_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_save_location_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

            <!--
              "Current: …" read-out as a chip. textIsSelectable lets
              the user copy the resolved folder name (handy for
              support reports) without scrambling for a Toast.
            -->
            <TextView
                android:id="@+id/main_save_location_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/qr_url_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                android:textIsSelectable="true"
                tools:text="Current: Downloads (default)" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/main_save_location_pick"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_save_location_pick" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/main_save_location_clear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_save_location_clear" />

            </LinearLayout>

        </LinearLayout>

        <!--
          ============ Card 2: Advertised name ============

          Visible receiver-name override for Quick Share discovery.
          The underlying [AdvertisedDeviceNames] storage refreshes the
          active receiver session after save/reset, and the pre-merge
          debug-loop regression matrix covers custom-name discovery in
          both GMS-to-Bada and Bada-to-GMS directions.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/main_advertised_name_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_advertised_name_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/main_advertised_name_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_advertised_name_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

            <!--
              Currently-advertised name shown as a chip read-out
              above the editor so the user can see what peers are
              seeing right now without having to reason about the
              EditText's empty-vs-default state.
            -->
            <TextView
                android:id="@+id/main_advertised_name_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/qr_url_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                android:textIsSelectable="true"
                tools:text="Currently advertised: V2547A" />

            <!--
              EditText wrapped in a soft chip surface (12dp corners,
              light gray fill, hairline). Replaces the bare
              underline-style EditText that was the only flat-line
              control left in the app. `background=null` on the
              inner widget would still pick up the platform's default
              underline drawable on some OEM skins, so we override
              with the chip drawable + matching internal padding.
            -->
            <EditText
                android:id="@+id/main_advertised_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/settings_input_background"
                android:hint="@string/main_advertised_name_hint"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:minHeight="48dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/main_advertised_name_save"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_advertised_name_save" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/main_advertised_name_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_advertised_name_reset" />

            </LinearLayout>

        </LinearLayout>

        <!-- ============ Card 3: Battery / background activity ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/settings_battery_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_battery_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_battery_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_battery_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/settings_battery_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/qr_url_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                android:textIsSelectable="true"
                tools:text="Currently: not exempt — receiving may stop in the background" />

            <Button
                android:id="@+id/settings_battery_open"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_battery_open" />

        </LinearLayout>

        <!-- ============ Card: Full-screen transfer alerts (API 34+) ============
             Hidden by default; SettingsFragment makes it visible only on
             Android 14+, where USE_FULL_SCREEN_INTENT became a grantable
             special access. Lets the consent PIN prompt pop full-screen
             over other apps / the lock screen when a transfer arrives
             while Bada is in the background. -->
        <LinearLayout
            android:id="@+id/settings_fsi_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/settings_fsi_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_fsi_title"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_fsi_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_fsi_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/settings_fsi_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/qr_url_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?android:attr/textColorPrimary"
                android:textIsSelectable="true"
                tools:text="Currently: full-screen alerts not allowed" />

            <Button
                android:id="@+id/settings_fsi_open"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_fsi_open" />

        </LinearLayout>

        <!-- ============ Card 4: Keep screen on during transfers ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_keep_screen_on_title"
                    android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/main_keep_screen_on_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/main_keep_screen_on_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_keep_screen_on_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>

        <!-- ============ Card 5: Shake-to-report bug ============ -->
        <!--
          Switch row: title and Switch share a horizontal row so
          the toggle's affordance reads against its label. Subtitle
          drops below as a single block so the wider explanation
          doesn't squeeze the switch column. Mirrors the standard
          Material settings-row pattern (title-left + control-right
          + supporting text below).
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_bug_report_title"
                    android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/main_bug_report_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/main_bug_report_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_bug_report_subtitle"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
