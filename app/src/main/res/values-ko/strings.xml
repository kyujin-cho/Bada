<?xml version="1.0" encoding="utf-8"?>
<!--
  Korean (`ko`) string overrides. The Android resource system
  picks this file for any device whose primary locale resolves to
  Korean (`ko`, `ko-rKR`, `ko-rKP`); every other locale falls back
  to the canonical English copy in `values/strings.xml`. Only the
  strings the product owner has explicitly translated live here, so
  any string we do not list keeps the English text on a Korean
  device — preferred over a half-machine-translated UI.

  Pairing additions: when adding a new translatable string, add the
  English copy in `values/strings.xml` first, then the Korean
  rendering here. Keep the resource name identical between both
  files.
-->
<resources>
    <!-- QR sharing panel inside SendActivity. -->
    <string name="show_qr_title">QR 코드 또는 링크</string>
    <string name="show_qr_intro">파일을 받을 사람에게 QR 코드 스캔 또는 링크 접속을 요청하세요. QR 코드나 링크를 보유한 사람은 누구나 내 허락 없이 파일을 열 수 있습니다.</string>

    <!-- Credit screen, QA section. Chiyak's tagline differs between
         locales: the Korean rendering is a literal translation of the
         English "I wanna buy a concert ticket". TEQHNIKACROSS's tagline
         is intentionally kept identical to its English form (no entry
         here) so it reads as "We all want to be loved" on Korean
         devices too. -->
    <string name="credit_chiyak_qa_desc">콘서트 티켓이 사고 싶어요</string>

    <!-- Credit screen, Developer section. Korean rendering of Kevin's
         tagline; the canonical English form ("I'm running low on
         miles") lives in `values/strings.xml`. -->
    <string name="credit_kevin_desc">마일리지가 모자라요</string>
</resources>
