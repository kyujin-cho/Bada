    <string name="send_activity_label">Send via Quick Share</string>
    <string name="send_subtitle_discovering">Looking for nearby devices…</string>
    <string name="send_subtitle_pick_peer">Tap a device to send.</string>
    <string name="send_subtitle_no_usable_route">Nearby device found, but no supported transfer route is available yet.</string>
    <string name="send_empty_state">No devices nearby yet. Make sure the receiver has Quick Share open.</string>

    <!-- Same-Wi-Fi-network hint card (#85). Surfaced after a few seconds
         of empty peer list so the user understands why nothing has
         appeared. Condensed wording — the full explanation lives in
         the onboarding card. -->
    <string name="send_network_hint_title">Nearby discovery requirements</string>
    <string name="send_network_hint_body">Shared Wi-Fi is still the baseline path. Some receivers can be named from BLE before they expose a supported transfer route; connect both devices to the same Wi-Fi network or keep Bluetooth available for supported bootstrap paths.</string>
    <string name="send_network_hint_dismiss">Got it</string>
    <!-- "Can't find the device?" link rendered above the Cancel
         button in the picker state. Tapping it opens a bottom sheet
         with two short sections: confirm the receiver is in
         "Ready to receive" mode, and (fallback) use the QR / link
         share at the top right. The link itself is underlined and
         centred, sized at the small caption text style. -->
    <string name="send_help_link">Can\'t find the device?</string>

    <!-- Bottom sheet content for the "Can't find the device?" link.
         Two sections — receiver visibility check + QR fallback —
         keyed off the two reasons a peer would not appear in the
         scan list. -->
    <string name="send_help_sheet_title">Can\'t find the device?</string>
    <string name="send_help_sheet_visibility_title">Check the receiver\'s mode</string>
    <string name="send_help_sheet_visibility_body">On the receiving device, make sure the toggle reads "Ready to receive". In that mode, anyone nearby can share files with it. If it\'s already in that mode but still doesn\'t appear here, try fully closing Bada on both devices and reopening it.</string>
    <string name="send_help_sheet_qr_title">Or share via QR code</string>
    <string name="send_help_sheet_qr_body">If the receiver still does not appear, tap the QR code button at the top right of this card. Have the receiver scan the code or open the link to start the transfer.</string>
    <string name="send_help_sheet_compat_title">Check device compatibility</string>
    <string name="send_help_sheet_compat_body">Bada is currently an experimental project. On some devices a peer may be discoverable but unable to receive files, and some devices may not be discoverable at all. We plan to widen device support in future updates.</string>
    <string name="send_help_sheet_close">Got it</string>

