    <!-- Consent trampoline (#22). -->
    <string name="consent_activity_label">Incoming transfer</string>
    <!-- Short header above the 4-digit confirmation PIN. Replaces the
         older sentence-form "Confirm this 4-digit code…" with a
         minimal uppercase label so the PIN itself is the dominant
         element on the line. -->
    <string name="consent_pin_label">PIN</string>
    <string name="consent_files_label">Files to receive</string>
    <string name="consent_button_accept">Accept</string>
    <string name="consent_button_reject">Reject</string>
    <string name="consent_unknown_sender">A nearby device wants to share</string>
    <!-- Type-specific consent title templates, picked at render time
         based on the announced payload's mime types. The classifier
         reads as "all items are images" → images, "all items are
         videos" → videos, otherwise → files (covers mixed types,
         text payloads, documents, archives). %1$s is the sender's
         device name. The legacy single-shape title remains for
         compat / fallback callers. -->
    <string name="consent_title_with_name">%1$s wants to share</string>
    <string name="consent_title_with_name_images">%1$s wants to share images</string>
    <string name="consent_title_with_name_videos">%1$s wants to share videos</string>
    <string name="consent_title_with_name_files">%1$s wants to share files</string>
    <string name="consent_summary_n_items">%1$d item(s) (%2$s)</string>
    <string name="consent_summary_no_items">no items</string>
    <!-- Folder-receive summary (#39). Shown when every announced file
         shares the same root parent_folder. -->
    <string name="consent_summary_folder">Folder \"%1$s\" (%2$d file(s), %3$s)</string>
    <!--
      Per-item rows in the consent dialog's file list. Each row is
      rendered as a single TextView with the file / item name on the
      first line and the human-readable size on the second line —
      `\n` is interpreted as a hard line break. Both lines render
      centre-aligned (gravity set in code on the TextView), matching
      the rest of the consent panel's centred axis.
    -->
    <string name="consent_file_line">%1$s\n%2$s</string>
    <string name="consent_text_line_with_title">%1$s\n%2$s</string>
    <string name="consent_more_items">…and %1$d more</string>
    <string name="consent_dismissed">Transfer no longer pending</string>

    <!--
      Post-Accept consent flow states (receiving → completed / failed).
      The trampoline activity stays foreground after the user taps
      Accept and renders these as it observes the in-flight
      InboundConnection's state.
    -->
    <string name="consent_state_receiving">Receiving…</string>
    <string name="consent_state_progress">%1$s / %2$s</string>
    <string name="consent_state_completed">Transfer complete</string>
    <string name="consent_state_completed_one">1 file received</string>
    <string name="consent_state_completed_many">%1$d files received</string>
    <string name="consent_state_failed">Transfer failed</string>
    <string name="consent_state_cancelled">Transfer cancelled</string>
    <string name="consent_state_view_image">View image</string>
    <string name="consent_state_close">Close</string>
    <string name="consent_state_view_image_unavailable">No app can open this image.</string>

    <!--
      Integer percentage label rendered in the centre of the circular
      progress disc on both the sender's Sending state and the
      receiver's Receiving state. Uses %% so the literal `%` glyph
      survives string formatting unchanged.
    -->
    <string name="transfer_progress_percent">%1$d%%</string>

    <!--
      Quick Settings tile (BadaQuickShareTileService). Toggles the
      receiver's "always visible" override from the system Quick Settings
      panel. `qs_tile_label` is also the tile's manifest android:label
      (shown in the Quick Settings edit tray) — keep it under ~18 chars
      and untranslated (proper noun). The subtitle/state strings render
      under the tile label on API 29+; the content descriptions back
      TalkBack on every API level.
    -->
    <string name="qs_tile_label">Bada</string>
    <string name="qs_tile_subtitle_on">Discoverable</string>
    <string name="qs_tile_subtitle_off">Off</string>
    <string name="qs_tile_content_desc_on">Bada is discoverable to nearby devices</string>
    <string name="qs_tile_content_desc_off">Bada is not discoverable</string>
</resources>
