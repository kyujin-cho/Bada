    <!-- File-picker entry point on the Send/Receive tab. Opens
         ACTION_OPEN_DOCUMENT with EXTRA_ALLOW_MULTIPLE so the user can
         pick one or more files of any MIME type from the gallery, the
         documents UI, or any other DocumentsProvider on the device. The
         resulting URIs are forwarded to SendActivity as
         ACTION_SEND_MULTIPLE / EXTRA_STREAM (single picks degrade to
         ACTION_SEND). -->
    <string name="main_send_files_button">Send files</string>
    <string name="main_send_files_subtitle">Pick one or more files from this device — photos, documents, anything — and send them to a nearby Quick Share peer.</string>
    <string name="main_send_files_pick_failed">Could not open the file picker on this device.</string>
    <string name="main_send_files_no_selection">No files were selected.</string>

    <!-- Idle state caption shown above the photo preview cards on the
