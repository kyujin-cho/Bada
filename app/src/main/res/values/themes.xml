<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Theme parent uses the MaterialComponents `.Bridge` variant so
      MainActivity can host a BottomNavigationView (which requires a
      MaterialComponents-derived theme) while every existing
      AppCompat-based widget keeps its current behavior. The Bridge
      theme intentionally does NOT override AppCompat widget styles, so
      SwitchCompat / EditText / Button etc. continue to look the same;
      only widgets that explicitly opt into Material styles (e.g.
      BottomNavigationView) get the Material treatment.

      Theme-level color + system-bar settings:
        * `colorPrimary` is wired to the brand blue so any Material
          widget that reads the primary token (BottomNavigationView's
          active-state defaults, ripple highlights, etc.) picks it up
          without needing per-widget overrides.
        * `android:statusBarColor` is set to the window background so
          the system status bar blends with the activity surface
          rather than rendering as a dark band on Android 12 / 13 / 14.
          On Android 15+ (API 35+) this attribute is a no-op because
          edge-to-edge is enforced; we rely on the layout-side
          `fitsSystemWindows` opt-in for the inset handling instead.
        * `windowLightStatusBar` follows `@bool/window_light_status_bar`
          so the status bar icon color flips with DayNight. Light mode
          uses dark glyphs on the light background; night mode uses
          light glyphs on the dark background.
    -->
    <style name="Theme.Bada" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>

        <!--
            App-wide brand face. Google Sans Flex is delivered via
            Downloadable Fonts (see `res/font/google_sans_flex.xml`);
            its glyph coverage is Latin + extended Latin only, and
            the platform's standard glyph-fallback chain takes over
            for Hangul / CJK so Korean strings keep rendering with
            the system Korean font without us having to maintain a
            per-locale theme override.

            Both the AppCompat-namespaced (`fontFamily`) and the
            android-namespaced (`android:fontFamily`) attributes are
            set: AppCompat widgets read the former, framework widgets
            (Toolbar title, AlertDialog title/message, system text
            views) read the latter.
        -->
        <item name="fontFamily">@font/google_sans_flex</item>
        <item name="android:fontFamily">@font/google_sans_flex</item>

        <item name="android:statusBarColor" tools:targetApi="l">?android:attr/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">@bool/window_light_status_bar</item>

        <!--
          Custom popup style for the toolbar overflow menu. Replaces
          the default near-square popup background with a 16dp rounded
          rectangle so the kebab popup matches the vivo / OriginOS
          native look. Both `actionOverflowMenuStyle` (the toolbar's
          own overflow) and `popupMenuStyle` (any in-code PopupMenu
          we open later) point to the same style for consistency.
        -->
        <item name="actionOverflowMenuStyle">@style/PopupMenu.Bada</item>
        <item name="popupMenuStyle">@style/PopupMenu.Bada</item>

        <!--
          Global button styling. Replaces AppCompat's default flat
          gray rectangle with a frosted-glass-style background
          (`btn_frosted_background`) at 24dp corner radius — applied
          automatically to every plain `<Button>` in the app via the
          AppCompat `buttonStyle` attribute. Borderless variants
          (`?android:attr/borderlessButtonStyle`) opt out
          per-Button.
        -->
        <item name="buttonStyle">@style/Widget.Bada.Button</item>
        <item name="android:buttonStyle">@style/Widget.Bada.Button</item>

        <!--
          Override the platform-default Button text appearance
          (`TextAppearance.AppCompat.Widget.Button`) which forces
          `textAllCaps=true`. Using `?android:attr/textAppearanceButton`
          as the resolution path means even Buttons that opt out of
          our `Widget.Bada.Button` style (e.g. the
          `?android:attr/borderlessButtonStyle` Skip / Reset variants)
          still get the casing-preserved text.
        -->
        <item name="android:textAppearanceButton">@style/TextAppearance.Bada.Button</item>
    </style>

    <!--
      Button text appearance with `textAllCaps=false` baked in. Every
      Button in the app reads its text style from this appearance via
      either `Widget.Bada.Button` (the buttonStyle override
      above) or the activity-theme `android:textAppearanceButton`
      attribute, so the previously-uppercased labels render in their
      natural string-resource casing ("Send files" stays "Send files"
      instead of becoming "SEND FILES"). Bold weight is kept here so
      borderless variants — which inherit this appearance but not the
      Widget.Bada.Button style — still read with the same visual
      weight as the framed buttons.
    -->
    <style name="TextAppearance.Bada.Button" parent="TextAppearance.AppCompat.Widget.Button">
        <item name="android:textAllCaps">false</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Bada.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_frosted_background</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textAppearance">@style/TextAppearance.Bada.Button</item>
        <!--
          Two-pronged textAllCaps override (android: + bare attr)
          guarantees the casing is preserved no matter which
          framework path the Button reads from on the running
          platform — some Android builds prefer the bare appcompat
          attr resolution, others go straight to the platform
          android: namespace.
        -->
        <item name="android:textAllCaps">false</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <!--
          Centering belt-and-suspenders. AppCompatButton (Bridge
          theme keeps it on AppCompat, no MaterialButton promotion)
          was rendering text shifted noticeably LEFT of the button's
          geometric center on this device. Root cause not fully
          isolated, but combinations of these symptoms suggest
          inherited padding asymmetry from `Widget.AppCompat.Button`
          interacting with `paddingLeft`/`Right` set in dp:
            * Reset all padding to 0 first, then explicitly
              re-apply as paddingStart/paddingEnd (RTL-aware) so
              the parent style's defaults can't bleed through.
            * Both `android:gravity="center"` AND
              `android:textAlignment="center"` so whichever path the
              runtime resolves alignment from, it reads "center".
        -->
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:maxLines">2</item>
        <!--
          Zero out drawable-related space the platform Button's
          parent style typically reserves. `drawablePadding` is the
          gap between an inline compound drawable and the text;
          even with no drawable set, the platform allocates this
          space for layout stability. On Korean bold text long
          enough to need most of the button width, that reserved
          gap pushed the text visibly LEFT of the button's
          geometric center. Forcing `drawablePadding=0dp` removes
          the asymmetric reservation so `gravity=center` actually
          centers the text against the button centerline.
        -->
        <item name="android:drawablePadding">0dp</item>
        <!--
          When MaterialComponents *does* promote (e.g. inside the
          consent dialog's Material theme overlay), these
          MaterialButton-specific attrs pull the (empty) icon slot
          out of the horizontal layout so it cannot push the text
          off-center.
        -->
        <item name="iconGravity">textTop</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="PopupMenu.Bada" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/popup_menu_background</item>
        <!--
          `overlapAnchor=false` pushes the popup down below the
          overflow icon instead of overlapping it; matches vivo's
          drop-down placement so the kebab stays visible while the
          menu is open.
        -->
        <item name="overlapAnchor">false</item>
    </style>

    <!--
      Theme for ConsentTrampolineActivity (#22). The activity is raised
      via the consent notification's `setFullScreenIntent` (see
      ConsentNotification.kt) so it appears as a floating card over
      whatever the user is doing — incoming-call UX. The dialog parent
      gives us:

        * A windowed (non-fullscreen) layout the platform sizes via
          windowMinWidthMajor / Minor — typically ~85% of the screen.
        * A platform dim layer behind the window for the modal feel.
        * Material widget tinting consistent with the rest of the app
          (colorPrimary etc.) without breaking the AppCompat-based
          widgets the layout uses.

      The rounded-card surface is painted by `consent_dialog_background`
      so the dialog reads as a clean card rather than the
      Material-default rectangular dialog. `windowIsFloating=true` is
      inherited from the Dialog parent and is what tells the platform
      to dim the underlying surface and constrain the window to dialog
      dimensions; we leave it as inherited.
    -->
    <style name="Theme.Bada.ConsentDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Bridge">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="android:windowBackground">@drawable/consent_dialog_background</item>

        <!--
            Mirror the Theme.Bada brand-face declarations here —
            the consent dialog activity uses this theme directly, so
            without these the dialog body would fall back to platform
            Roboto while the rest of the app reads in Google Sans
            Flex. Keep these in sync with Theme.Bada.
        -->
        <item name="fontFamily">@font/google_sans_flex</item>
        <item name="android:fontFamily">@font/google_sans_flex</item>

        <!--
          Mirror the Theme.Bada button-style overrides here too —
          the dialog activity uses this theme directly (it extends the
          Material Bridge dialog parent, NOT Theme.Bada), so
          without these declarations the consent / receiving /
          completed / failed panel buttons fall back to the platform's
          default flat gray rectangle and uppercase text. Keep these
          two blocks in sync with Theme.Bada.
        -->
        <item name="buttonStyle">@style/Widget.Bada.Button</item>
        <item name="android:buttonStyle">@style/Widget.Bada.Button</item>
        <item name="android:textAppearanceButton">@style/TextAppearance.Bada.Button</item>
        <!--
          Suppress the platform-drawn dialog title. Without this, the
          Activity's `android:label` ("Incoming transfer") shows as a
          gray bar above our panel content, which reads stale once the
          flow has moved past consent into receiving / completed
          states. Each panel already carries its own headline TextView,
          so the activity-level title is redundant.

          Both the AppCompat-namespaced and android-namespaced versions
          are set: the Material dialog parent's window decoration goes
          through the AppCompat path on most APIs, and the platform
          path is the one PhoneWindow honors when the activity is laid
          out before AppCompat's decor inflater runs.
        -->
        <item name="windowNoTitle">true</item>
        <item name="android:windowNoTitle">true</item>
        <!--
          Match the dialog's width to the SendActivity card: 16dp
          horizontal margin from the screen edge ≈ 90% of screen
          width on every standard portrait Android device, which keeps
          the consent dialog visually congruent with the rest of the
          app's card-style surfaces. `Minor` covers portrait, `Major`
          covers landscape; both at the same percentage produces a
          consistent footprint regardless of orientation.
        -->
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowMinWidthMajor">90%</item>
    </style>

    <!--
      Toolbar title text style — larger and bolder than the platform
      default to match the vivo / OriginOS native header pattern (the
      "연락처" title on a vivo Contacts screen sits at ~26sp bold,
      noticeably bigger than AOSP's 20sp regular). The toolbar also
      uses an 88dp height with `paddingTop=32dp` so the title /
      action row hugs the bottom of the toolbar surface, which is
      where vivo positions theirs.
    -->
    <style name="TextAppearance.Bada.ToolbarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!--
      Bottom-nav label text style. Pinned to a single 12sp regular
      appearance so the active and inactive tab labels render at the
      identical size — Material's default is to render the active
      label slightly larger ("shifting" labels), which the user
      explicitly does not want; on vivo native bars the label size
      is constant and only the color changes between states.

      Applied to both `app:itemTextAppearanceActive` and
      `app:itemTextAppearanceInactive` on BottomNavigationView so
      neither state overrides the size.
    -->
    <style name="TextAppearance.Bada.BottomNavLabel" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
    </style>

    <!--
      Popup theme overlay applied to MainActivity's MaterialToolbar via
      `app:popupTheme`. Overrides `listPreferredItemHeightSmall`
      (default 48dp on MaterialComponents) to 38dp — about a 20% cut
      from the AOSP default — so each overflow row becomes more
      compact, matching the vivo / OriginOS popup density.

      Parented on `ThemeOverlay.AppCompat.DayNight` (NOT the older
      `…AppCompat.Light` we used initially) so popup item text /
      surface follow the system mode. Forcing `Light` made the
      kebab popup render with a black-on-dark item label in night
      mode — invisible against the dark popup_menu_surface.

      The height override is applied to BOTH the AppCompat-namespaced
      and android-namespaced versions of the attribute because the
      MaterialComponents popup item layout reads the AppCompat one
      while older AppCompat fallbacks read the platform one; setting
      both keeps behavior identical regardless of which path the
      runtime picks.
    -->
    <style name="ThemeOverlay.Bada.PopupMenu" parent="ThemeOverlay.AppCompat.DayNight">
        <item name="listPreferredItemHeightSmall">38dp</item>
        <item name="android:listPreferredItemHeightSmall">38dp</item>
    </style>

    <!--
      Theme overlay applied to MainActivity's MaterialToolbar via
      `app:theme`. Swaps the platform-default circular ripple
      (`?attr/actionBarItemBackground`) on toolbar action items
      (currently the kebab / overflow icon) for a flat rectangular
      state-list wash (`@drawable/toolbar_action_background`) so
      tapping the kebab reads as "the icon brightens slightly" rather
      than firing a circular ripple animation. The override is
      isolated to a theme overlay (rather than the global app theme)
      so popup menus and dialog action items elsewhere keep their
      default Material ripples.
    -->
    <style name="ThemeOverlay.Bada.ToolbarNoRipple" parent="">
        <item name="actionBarItemBackground">@drawable/toolbar_action_background</item>
        <item name="android:actionBarItemBackground">@drawable/toolbar_action_background</item>
    </style>

    <!--
      Shape overlay used by the Credit screen's avatar ShapeableImageViews
      so the contributor photos clip with the same 12dp rounded corners as
      the gradient `credit_avatar_placeholder` drawable. Without this
      overlay a raster avatar would render as a hard-edged square next to
      the placeholder's soft corners and the rows would read as visually
      inconsistent.
    -->
    <style name="ShapeAppearanceOverlay.Bada.CreditAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
